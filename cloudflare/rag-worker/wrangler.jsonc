{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "simulatore-rag-api",
  "main": "src/index.js",
  "compatibility_date": "2026-04-05",
  "vars": {
    "ALLOWED_ORIGIN": "https://alquati99-simulatore.pages.dev",
    "RAG_LLM_MODEL": "@cf/meta/llama-3.1-8b-instruct-fast",
    "RAG_EMBED_MODEL": "@cf/baai/bge-m3",
    "RAG_TOP_K": "6"
  },
  "ai": {
    "binding": "AI"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "simulatore-rag",
      "database_id": "d101a1dd-f7d4-4fe0-a769-632a0e772a44"
    }
  ],
  "vectorize": [
    {
      "binding": "KNOWLEDGE_INDEX",
      "index_name": "simulatore-knowledge"
    }
  ]
}
